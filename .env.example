# --- App ---
UPLOAD_DIR=data/uploads
DB_PATH=data/escrow.db

# --- Model backend toggle ---
# true  -> AWS Bedrock (uses AWS_* and BEDROCK_* below)
# false -> direct Anthropic API (uses ANTHROPIC_API_KEY + MODEL_ID)
AGENT_USE_BEDROCK=true

# --- AWS Bedrock ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only set if you're using SSO / temporary credentials
AWS_SESSION_TOKEN=

BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_TEMPERATURE=0
BEDROCK_MAX_TOKENS=8192

# --- Direct Anthropic API (only used when AGENT_USE_BEDROCK=false) ---
ANTHROPIC_API_KEY=
MODEL_ID=claude-sonnet-4-6
